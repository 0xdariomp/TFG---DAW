---
// Gallery.astro
---
<!-- GALERÍA -->
<div class="section-full" id="galeria">
    <div class="inner">
        <div class="slabel">Nuestro Trabajo</div>
        <h2 class="stitle">Galería</h2>
        <p class="ssub">Resultados reales en clientes reales. El trabajo habla solo.</p>
        <div class="gallery-grid">
            <div class="g-item">
                <img src="/peluqueria-fuera.jpg" alt="Fachada Barbería VIP Granada"
                     onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
                <div class="g-placeholder" style="display:none"><i class="fas fa-store"></i><span>Nuestra Barbería</span></div>
                <div class="g-overlay"><span class="g-caption">La Barbería</span></div>
            </div>
            <div class="g-item">
                <img src="/peluqueria-fuera2.jpg" alt="Entrada Barbería VIP Granada"
                     onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
                <div class="g-placeholder" style="display:none"><i class="fas fa-door-open"></i><span>Entrada</span></div>
                <div class="g-overlay"><span class="g-caption">La Entrada</span></div>
            </div>
            <div class="g-item">
                <img src="/materiales.jpg" alt="Herramientas y materiales Barbería VIP"
                     onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
                <div class="g-placeholder" style="display:none"><i class="fas fa-tools"></i><span>El Material</span></div>
                <div class="g-overlay"><span class="g-caption">Nuestras Herramientas</span></div>
            </div>
            <div class="g-item">
                <div class="g-placeholder"><i class="fas fa-user-tie"></i><span>Corte + Barba</span></div>
                <div class="g-overlay"><span class="g-caption">Look Completo</span></div>
            </div>
            <div class="g-item">
                <div class="g-placeholder"><i class="fas fa-layer-group"></i><span>Skin Fade</span></div>
                <div class="g-overlay"><span class="g-caption">Skin Fade</span></div>
            </div>
        </div>
    </div>
</div>
