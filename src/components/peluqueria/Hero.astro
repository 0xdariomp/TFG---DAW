---
// Hero.astro
---
<!-- HERO -->
<section class="hero" id="inicio">
    <div class="hero-bg"></div>
    <div class="hero-grid-lines"></div>
    <div class="hero-content">
        <div class="hero-badge">Barbería · Granada · Desde 2018</div>
        <h1>Tu mejor<br><span class="line-gold">versión</span></h1>
        <div class="hero-divider"></div>
        <p>Cortes para caballeros que saben lo que quieren. Precisión, estilo y ambiente exclusivo en el corazón de Granada.</p>
        <div class="hero-btns">
            <a href="#reservar" class="btn-gold"><i class="fas fa-calendar-check"></i> Reservar Cita</a>
            <a href="#servicios" class="btn-ghost">Ver Servicios</a>
        </div>
    </div>
    <div class="hero-scroll"><i class="fas fa-chevron-down"></i><span>Descubrir</span></div>
</section>
