---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="ChatBot IA Empresarial | Darío Martínez"
  description="ChatBot inteligente con IA integrado en Odoo Discuss. Crea canales automáticamente y desplegado en producción en Close Marketing."
  lang="es"
>

<style>
    .doc-wrap { max-width: 1100px; margin: 0 auto; padding: 60px 40px 120px; }

    .doc-back {
        display: inline-flex; align-items: center; gap: 10px;
        color: var(--accent-cyan); text-decoration: none;
        font-family: 'Space Mono', monospace; font-size: 0.85rem; letter-spacing: 1px;
        transition: var(--transition); margin-bottom: 48px;
    }
    .doc-back:hover { transform: translateX(-5px); text-shadow: 0 0 20px rgba(6,182,212,.6); }

    .page-hero { text-align: center; margin-bottom: 80px; animation: slideInDown 0.7s ease-out; }
    .page-cat {
        display: inline-block; font-size: 0.72rem; font-weight: 700;
        letter-spacing: 4px; text-transform: uppercase; color: var(--accent-purple);
        padding: 6px 18px; border: 1px solid rgba(168,85,247,.3); border-radius: 50px; margin-bottom: 22px;
    }
    .page-hero h1 { font-size: clamp(2rem, 5vw, 3rem); margin-bottom: 16px; text-shadow: 0 0 40px rgba(168,85,247,.4); }
    .page-hero p { color: var(--text-muted); font-size: 1rem; max-width: 560px; margin: 0 auto 30px; line-height: 1.8; }
    .chip-row { display: flex; flex-wrap: wrap; gap: 8px; justify-content: center; }
    .chip { padding: 5px 14px; border-radius: 50px; font-size: 0.77rem; }
    .chip-p { background: rgba(168,85,247,.07); border: 1px solid rgba(168,85,247,.25); color: var(--accent-purple); }
    .chip-c { background: rgba(6,182,212,.07); border: 1px solid rgba(6,182,212,.2); color: var(--accent-cyan); }

    .live-badge {
        display: inline-flex; align-items: center; gap: 6px;
        background: rgba(239,68,68,.1); border: 1px solid rgba(239,68,68,.3);
        border-radius: 50px; padding: 5px 14px; font-size: 0.72rem; font-weight: 700;
        color: #ef4444; letter-spacing: 1px; text-decoration: none;
        transition: var(--transition); margin-left: 12px; vertical-align: middle;
    }
    .live-badge::before { content: '●'; animation: blink 1.2s step-end infinite; }
    .live-badge:hover { background: rgba(239,68,68,.2); }

    /* MAIN SPLIT */
    .cb-split { display: grid; grid-template-columns: 1fr 1fr; gap: 50px; align-items: center; margin-bottom: 70px; }
    .ps-block h3 { font-size: 1rem; margin-bottom: 10px; }
    .ps-block p { color: var(--text-muted); font-size: 0.92rem; line-height: 1.8; margin-bottom: 22px; }

    .cb-visual {
        background: linear-gradient(135deg, rgba(168,85,247,.1), rgba(6,182,212,.1));
        border: 2px solid var(--border-color-bright); border-radius: 16px;
        padding: 50px 36px; display: flex; flex-direction: column; align-items: center;
        justify-content: center; min-height: 300px; position: relative; overflow: hidden;
    }
    .cb-visual::before {
        content: ''; position: absolute; top:-50%; right:-50%; width:200%; height:200%;
        background: radial-gradient(circle, rgba(168,85,247,.15), transparent 60%);
        animation: float 8s ease-in-out infinite;
    }
    .cb-icon {
        font-size: 4.5rem; background: linear-gradient(135deg, var(--accent-purple), var(--accent-cyan));
        -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
        position: relative; z-index: 1; animation: pulse 2s ease-in-out infinite; margin-bottom: 18px;
    }
    .cb-term { font-family: 'Space Mono', monospace; font-size: 0.8rem; color: var(--accent-cyan);
        text-align: center; position: relative; z-index: 1; }
    .cb-term .bl::after { content: '_'; animation: blink 1.2s step-end infinite; }

    /* FEATURES */
    .feat-title { text-align: center; font-size: 1.8rem; margin: 70px 0 40px; }
    .feat-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-bottom: 70px; }
    .feat-box {
        background: var(--bg-light); border: 1px solid var(--border-color);
        border-radius: 12px; padding: 28px 22px; transition: var(--transition); position: relative; overflow: hidden;
    }
    .feat-box::before {
        content: ''; position: absolute; top:0; left:-100%; width:100%; height:2px;
        background: linear-gradient(90deg, transparent, var(--accent-purple), transparent);
        animation: shine 3s infinite;
    }
    @keyframes shine { 0%{left:-100%} 60%{left:100%} 100%{left:100%} }
    .feat-box:hover { border-color: var(--accent-purple); background: rgba(168,85,247,.04); transform: translateY(-7px); box-shadow: 0 18px 40px rgba(168,85,247,.13); }
    .feat-icon { font-size: 2rem; color: var(--accent-purple); margin-bottom: 14px; }
    .feat-box h3 { font-size: 0.94rem; color: var(--text-primary); margin-bottom: 9px; }
    .feat-box p { font-size: 0.83rem; color: var(--text-muted); line-height: 1.6; }

    /* ARCHITECTURE */
    .arch-wrap {
        background: linear-gradient(135deg, rgba(6,182,212,.04), rgba(168,85,247,.04));
        border: 1px solid var(--border-color-bright); border-radius: 16px;
        padding: 44px 36px; margin-bottom: 70px;
    }
    .arch-wrap h3 { text-align: center; margin-bottom: 36px; font-size: 1.3rem; }
    .arch-flow { display: flex; align-items: center; justify-content: center; gap: 10px; flex-wrap: wrap; }
    .arch-node {
        flex: 1; min-width: 110px; max-width: 160px; text-align: center;
        padding: 20px 14px; background: var(--bg-dark);
        border: 1px solid var(--border-color); border-radius: 10px; transition: var(--transition);
    }
    .arch-node:hover { border-color: var(--accent-cyan); transform: scale(1.06); box-shadow: 0 8px 24px rgba(6,182,212,.15); }
    .arch-node i { font-size: 1.7rem; color: var(--accent-cyan); display: block; margin-bottom: 7px; }
    .arch-node strong { display: block; font-size: 0.8rem; color: var(--text-primary); margin-bottom: 4px; }
    .arch-node p { font-size: 0.72rem; color: var(--text-muted); margin: 0; line-height: 1.3; }
    .arch-arrow { font-size: 1.1rem; color: var(--accent-cyan); opacity: .45; flex: 0 0 auto; }

    /* IMPACT */
    .impact-title { text-align: center; font-size: 1.8rem; margin: 70px 0 36px; }
    .impact-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-bottom: 70px; }
    .impact-card {
        background: var(--bg-light); border: 1px solid var(--border-color);
        border-radius: 12px; padding: 28px 16px; text-align: center; transition: var(--transition);
    }
    .impact-card:hover { border-color: var(--accent-cyan); background: rgba(6,182,212,.04); transform: translateY(-8px); box-shadow: 0 14px 35px rgba(6,182,212,.15); }
    .impact-num { font-family: 'VT323', monospace; font-size: 2.4rem; color: var(--accent-cyan); margin-bottom: 8px; letter-spacing: 2px; }
    .impact-lbl { font-size: 0.74rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1px; line-height: 1.4; }

    /* CTA */
    .cta-box {
        text-align: center; padding: 56px 40px;
        background: linear-gradient(135deg, rgba(168,85,247,.08), rgba(6,182,212,.08));
        border: 1px solid var(--border-color-bright); border-radius: 16px;
    }
    .cta-box h2 { margin-bottom: 14px; font-size: 1.7rem; }
    .cta-box p { color: var(--text-muted); margin-bottom: 30px; }
    .btn-row { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }

    .sibling-link {
        display: inline-flex; align-items: center; gap: 8px;
        margin-top: 40px; padding: 12px 24px;
        border: 1px solid var(--border-color); border-radius: 50px;
        color: var(--text-muted); font-size: 0.8rem; text-decoration: none;
        transition: var(--transition); letter-spacing: 0.5px;
    }
    .sibling-link:hover { border-color: var(--accent-cyan); color: var(--accent-cyan); }

    @media(max-width:1024px) { .feat-grid { grid-template-columns: repeat(2,1fr); } .cb-split { grid-template-columns: 1fr; gap:36px; } }
    @media(max-width:768px) { .doc-wrap{padding:40px 20px 80px;} .feat-grid{grid-template-columns:1fr;} .arch-flow{flex-direction:column;} .arch-arrow{transform:rotate(90deg);} .impact-grid{grid-template-columns:repeat(2,1fr);} }
</style>


<div class="doc-wrap fade">
    <a href="/" class="doc-back"><i class="fas fa-arrow-left"></i><span data-es="Volver al Portfolio" data-en="Back to Portfolio">Volver al Portfolio</span></a>

    <div class="page-hero">
        <div class="page-cat" data-es="Proyecto · IA Empresarial" data-en="Project · Enterprise AI">Proyecto · IA Empresarial</div>
        <h1 data-es="ChatBot IA Empresarial" data-en="Enterprise AI ChatBot">
            ChatBot IA Empresarial
            <a href="https://close.marketing/prueba%20Clo" target="_blank" rel="noopener" class="live-badge">LIVE</a>
        </h1>
        <p data-es="Asistente inteligente con procesamiento de lenguaje natural, desplegado en producción para Close Marketing e integrado con Odoo Discuss para creación automática de canales." data-en="Intelligent assistant with natural language processing, deployed in production for Close Marketing and integrated with Odoo Discuss for automatic channel creation.">
            Asistente con NLP desplegado en producción para Close Marketing e integrado con Odoo Discuss para creación automática de canales.
        </p>
        <div class="chip-row">
            <span class="chip chip-p">OpenAI / LLM</span>
            <span class="chip chip-c">Odoo API</span>
            <span class="chip chip-c">REST API</span>
            <span class="chip chip-c">JavaScript</span>
            <span class="chip chip-c">WebSockets</span>
        </div>
    </div>

    <!-- CHALLENGE / SOLUTION -->
    <div class="cb-split">
        <div>
            <div class="ps-block">
                <h3 style="color:var(--accent-purple)" data-es="El Desafío" data-en="The Challenge">El Desafío</h3>
                <p data-es="Odoo necesitaba un sistema de chat que no solo respondiera preguntas, sino que crease automáticamente canales Discuss según el contexto de la conversación — sin intervención manual — y mantuviese coherencia a lo largo del tiempo." data-en="Odoo needed a chat system that not only answered questions but automatically created Discuss channels based on conversation context — without manual intervention — and maintained coherence over time.">
                    Odoo necesitaba un chat que crease canales Discuss automáticamente según contexto y mantuviese coherencia a lo largo del tiempo, sin intervención humana.
                </p>
                <h3 style="color:var(--accent-cyan)" data-es="La Solución" data-en="The Solution">La Solución</h3>
                <p data-es="ChatBot con LLMs integrado profundamente en Odoo. Analiza conversaciones en tiempo real, detecta temas clave, crea canales automáticamente y mantiene memoria persistente entre sesiones. Desplegado activamente en Close Marketing." data-en="ChatBot with LLMs deeply integrated into Odoo. Analyzes conversations in real time, detects key topics, creates channels automatically and maintains persistent memory across sessions. Actively deployed at Close Marketing.">
                    ChatBot con LLMs integrado en Odoo. Analiza en tiempo real, detecta temas, crea canales y mantiene memoria persistente. Activo en Close Marketing.
                </p>
            </div>
            <div class="chip-row" style="justify-content:flex-start">
                <span class="chip chip-p">LLM / GPT</span>
                <span class="chip chip-c">Odoo API</span>
                <span class="chip chip-c">JavaScript</span>
                <span class="chip chip-c">REST API</span>
            </div>
        </div>
        <div class="cb-visual">
            <div class="cb-icon"><i class="fas fa-robot"></i></div>
            <div class="cb-term">
                <div style="margin-bottom:8px" data-es="> CHATBOT v2.0 OPERATIVO" data-en="> CHATBOT v2.0 OPERATIONAL">> CHATBOT v2.0 OPERATIVO</div>
                <div style="opacity:.55;font-size:.74rem">IA + Odoo Discuss Sync</div>
                <div style="margin-top:10px;opacity:.35;font-size:.68rem" class="bl" data-es="esperando input..." data-en="waiting for input...">esperando input...</div>
            </div>
        </div>
    </div>

    <!-- FEATURES -->
    <h2 class="feat-title" data-es="Características" data-en="Features">Características</h2>
    <div class="feat-grid">
        <div class="feat-box">
            <div class="feat-icon"><i class="fas fa-brain"></i></div>
            <h3 data-es="IA Avanzada" data-en="Advanced AI">IA Avanzada</h3>
            <p data-es="LLMs compatibles con GPT-4 para respuestas contextuales, naturales y precisas en cualquier idioma." data-en="GPT-4 compatible LLMs for contextual, natural and accurate responses in any language.">LLMs compatibles con GPT-4 para respuestas naturales y precisas.</p>
        </div>
        <div class="feat-box">
            <div class="feat-icon"><i class="fas fa-sitemap"></i></div>
            <h3 data-es="Canales Automáticos" data-en="Auto Channels">Canales Automáticos</h3>
            <p data-es="Detecta temas nuevos en la conversación y crea canales Discuss en Odoo al instante." data-en="Detects new topics in conversation and creates Discuss channels in Odoo instantly.">Crea canales Discuss en Odoo automáticamente al detectar nuevos temas.</p>
        </div>
        <div class="feat-box">
            <div class="feat-icon"><i class="fas fa-memory"></i></div>
            <h3 data-es="Memoria Persistente" data-en="Persistent Memory">Memoria Persistente</h3>
            <p data-es="Contexto de sesiones anteriores disponible para respuestas siempre coherentes." data-en="Previous session context available for always coherent responses.">Contexto persistente entre sesiones para respuestas siempre coherentes.</p>
        </div>
        <div class="feat-box">
            <div class="feat-icon"><i class="fas fa-plug"></i></div>
            <h3 data-es="APIs Personalizadas" data-en="Custom APIs">APIs Personalizadas</h3>
            <p data-es="Webhooks y endpoints REST para conectar cualquier sistema externo al ecosistema." data-en="Webhooks and REST endpoints to connect any external system to the ecosystem.">Webhooks y REST endpoints para integraciones externas.</p>
        </div>
        <div class="feat-box">
            <div class="feat-icon"><i class="fas fa-shield-alt"></i></div>
            <h3 data-es="Seguridad &amp; RGPD" data-en="Security &amp; GDPR">Seguridad &amp; RGPD</h3>
            <p data-es="Cifrado end-to-end, gestión segura de sesiones y pleno cumplimiento del RGPD europeo." data-en="End-to-end encryption, secure session management and full EU GDPR compliance.">Cifrado end-to-end y cumplimiento RGPD en todos los flujos.</p>
        </div>
        <div class="feat-box">
            <div class="feat-icon"><i class="fas fa-rocket"></i></div>
            <h3 data-es="En Producción" data-en="In Production">En Producción</h3>
            <p data-es="Desplegado y activo en Close Marketing. Demo pública disponible y funcional en tiempo real." data-en="Deployed and active at Close Marketing. Public demo available and functional in real time.">Activo en Close Marketing con demo pública funcional.</p>
        </div>
    </div>

    <!-- ARCHITECTURE -->
    <div class="arch-wrap">
        <h3 data-es="Arquitectura Técnica" data-en="Technical Architecture">Arquitectura Técnica</h3>
        <div class="arch-flow">
            <div class="arch-node"><i class="fas fa-comment"></i><strong data-es="Usuario" data-en="User">Usuario</strong><p data-es="Envía mensaje" data-en="Sends message">Envía mensaje</p></div>
            <div class="arch-arrow"><i class="fas fa-arrow-right"></i></div>
            <div class="arch-node"><i class="fas fa-filter"></i><strong>NLP</strong><p data-es="Tokeniza y clasifica" data-en="Tokenize &amp; classify">Tokeniza y clasifica</p></div>
            <div class="arch-arrow"><i class="fas fa-arrow-right"></i></div>
            <div class="arch-node"><i class="fas fa-brain"></i><strong>LLM</strong><p data-es="Genera respuesta" data-en="Generates response">Genera respuesta</p></div>
            <div class="arch-arrow"><i class="fas fa-arrow-right"></i></div>
            <div class="arch-node"><i class="fas fa-database"></i><strong>Odoo API</strong><p data-es="Crea canal Discuss" data-en="Creates Discuss channel">Crea canal Discuss</p></div>
            <div class="arch-arrow"><i class="fas fa-arrow-right"></i></div>
            <div class="arch-node"><i class="fas fa-check-circle"></i><strong data-es="Respuesta" data-en="Response">Respuesta</strong><p data-es="Al usuario" data-en="To user">Al usuario</p></div>
        </div>
    </div>

    <!-- IMPACT -->
    <h2 class="impact-title" data-es="Impacto &amp; Resultados" data-en="Impact &amp; Results">Impacto &amp; Resultados</h2>
    <div class="impact-grid">
        <div class="impact-card"><div class="impact-num">95%</div><div class="impact-lbl" data-es="Precisión IA" data-en="AI Accuracy">Precisión IA</div></div>
        <div class="impact-card"><div class="impact-num">∞</div><div class="impact-lbl" data-es="Escalabilidad" data-en="Scalability">Escalabilidad</div></div>
        <div class="impact-card"><div class="impact-num">RT</div><div class="impact-lbl" data-es="Sincronización real-time" data-en="Real-time sync">Sincronización real-time</div></div>
        <div class="impact-card"><div class="impact-num">Live</div><div class="impact-lbl" data-es="En producción" data-en="In production">En producción</div></div>
    </div>

    <!-- CTA -->
    <div class="cta-box">
        <h2 data-es="¿Interesado en este tipo de soluciones?" data-en="Interested in this type of solution?">¿Interesado en este tipo de soluciones?</h2>
        <p data-es="Hablemos de tu proyecto. IA aplicada, integraciones y automatización." data-en="Let's talk about your project. Applied AI, integrations and automation.">Hablemos de tu proyecto. IA aplicada, integraciones y automatización.</p>
        <div class="btn-row">
            <a href="/#contact" class="btn btn-primary btn-glow"><i class="fas fa-envelope"></i><span data-es="Contactar" data-en="Contact">Contactar</span></a>
            <a href="https://close.marketing/prueba%20Clo" target="_blank" rel="noopener" class="btn btn-secondary btn-outline"><i class="fas fa-external-link-alt"></i><span data-es="Ver demo en vivo" data-en="See live demo">Ver demo en vivo</span></a>
            <a href="/" class="btn btn-secondary btn-outline"><i class="fas fa-home"></i><span data-es="Inicio" data-en="Home">Inicio</span></a>
        </div>
        <a href="/automatizaciones" class="sibling-link"><i class="fas fa-cogs"></i><span data-es="Ver también: Automatizaciones n8n →" data-en="See also: n8n Automations →">Ver también: Automatizaciones n8n →</span></a>
    </div>
</div>


</Layout>
