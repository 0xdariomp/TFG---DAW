<script is:inline>
    const BOOKING_KEY = 'vipgranada_booking_v1';
    const bk = { svc: null, price: null, dur: null, date: null, dateObj: null, time: null };
    let calYear, calMonth;

    // Header shadow on scroll
    window.addEventListener('scroll', () => {
        document.getElementById('hdr').style.boxShadow = window.scrollY > 50 ? '0 4px 30px rgba(0,0,0,.7)' : 'none';
    });

    // ---- ACTIVE BOOKING BANNER ----
    function renderBanner() {
        const raw = localStorage.getItem(BOOKING_KEY);
        const banner = document.getElementById('active-banner');
        banner.innerHTML = '';
        if (!raw) return;
        try {
            const b = JSON.parse(raw);
            banner.innerHTML = `
                <div class="active-booking-banner">
                    <div class="abn-info">
                        <span class="abn-icon">📅</span>
                        <div class="abn-text">
                            <strong>Cita activa: ${b.svc}</strong>
                            <p>${b.date} · ${b.time} · ${b.name}</p>
                        </div>
                    </div>
                    <button class="btn-cancel-booking" id="btn-cancel">Cancelar cita</button>
                </div>`;
            document.getElementById('btn-cancel').addEventListener('click', () => {
                if (confirm('¿Seguro que quieres cancelar tu cita?')) {
                    localStorage.removeItem(BOOKING_KEY);
                    renderBanner();
                }
            });
        } catch(e) { localStorage.removeItem(BOOKING_KEY); }
    }

    // ---- STEP NAVIGATION ----
    function goStep(n) {
        document.querySelectorAll('.fstep').forEach(s => s.classList.remove('active'));
        document.getElementById('s' + n).classList.add('active');
        updateDots(n);
    }

    function updateDots(n) {
        ['d1','d2','d3'].forEach((id, i) => {
            const d = document.getElementById(id);
            if (d) d.classList.toggle('done', i < (typeof n === 'number' ? n : 4));
        });
    }

    // ---- SERVICE SELECTION ----
    document.querySelectorAll('.svc-pick-btn').forEach(btn => {
        btn.addEventListener('click', () => {
            document.querySelectorAll('.svc-pick-btn').forEach(b => b.classList.remove('selected'));
            btn.classList.add('selected');
            bk.svc   = btn.dataset.svc;
            bk.price = btn.dataset.price;
            bk.dur   = btn.dataset.dur;
            document.getElementById('to2').disabled = false;
        });
    });
    document.getElementById('to2').addEventListener('click', () => { buildCalendar(); goStep(2); });

    // ---- CALENDAR ----
    function buildCalendar() {
        const now = new Date();
        if (!calYear) { calYear = now.getFullYear(); calMonth = now.getMonth(); }
        renderCal();
    }

    const MONTHS = ['Enero','Febrero','Marzo','Abril','Mayo','Junio','Julio','Agosto','Septiembre','Octubre','Noviembre','Diciembre'];

    function renderCal() {
        const grid = document.getElementById('cal-grid');
        grid.innerHTML = '';
        document.getElementById('cal-title').textContent = MONTHS[calMonth] + ' ' + calYear;

        ['L','M','X','J','V','S','D'].forEach(d => {
            const el = document.createElement('div');
            el.className = 'cal-day-lbl'; el.textContent = d;
            grid.appendChild(el);
        });

        const first = new Date(calYear, calMonth, 1);
        const offset = (first.getDay() + 6) % 7;
        const daysInMonth = new Date(calYear, calMonth + 1, 0).getDate();
        const today = new Date(); today.setHours(0,0,0,0);

        for (let i = 0; i < offset; i++) {
            const b = document.createElement('button');
            b.className = 'cal-day empty'; b.disabled = true; b.textContent = '';
            grid.appendChild(b);
        }

        for (let d = 1; d <= daysInMonth; d++) {
            const dt = new Date(calYear, calMonth, d);
            const btn = document.createElement('button');
            btn.className = 'cal-day';
            btn.textContent = d;
            const isPast = dt <= today;
            const isSun = dt.getDay() === 0;
            if (isPast || isSun) { btn.disabled = true; }
            else {
                btn.addEventListener('click', () => {
                    document.querySelectorAll('.cal-day').forEach(b => b.classList.remove('selected'));
                    btn.classList.add('selected');
                    bk.dateObj = dt;
                    bk.date = dt.toLocaleDateString('es-ES', {weekday:'long', day:'numeric', month:'long'});
                    bk.time = null;
                    renderTimeSlots(dt.getDay());
                    document.getElementById('to3').disabled = true;
                });
            }
            grid.appendChild(btn);
        }
    }

    document.getElementById('cal-prev').addEventListener('click', () => {
        calMonth--; if (calMonth < 0) { calMonth = 11; calYear--; } renderCal();
    });
    document.getElementById('cal-next').addEventListener('click', () => {
        calMonth++; if (calMonth > 11) { calMonth = 0; calYear++; } renderCal();
    });

    const TAKEN = ['10:00','11:30','16:00','17:30'];

    let toastTimer = null;
    function showToast(msg) {
        if (toastTimer) clearTimeout(toastTimer);
        let t = document.querySelector('.barber-toast');
        if (!t) {
            t = document.createElement('div');
            t.className = 'barber-toast';
            document.body.appendChild(t);
        }
        t.innerHTML = `<i class="fas fa-clock"></i> ${msg}`;
        requestAnimationFrame(() => t.classList.add('show'));
        toastTimer = setTimeout(() => {
            t.classList.remove('show');
            setTimeout(() => t.remove(), 400);
            toastTimer = null;
        }, 3200);
    }

    function renderTimeSlots(dow) {
        const grid = document.getElementById('time-grid');
        grid.innerHTML = '';
        const isSat = dow === 6;
        const slots = ['09:00','09:30','10:00','10:30','11:00','11:30','12:00','12:30',
                       '13:00','13:30','16:00','16:30','17:00','17:30','18:00','18:30','19:00'];
        const filtered = isSat ? slots.filter(s => s < '17:00') : slots;
        filtered.forEach(t => {
            const btn = document.createElement('button');
            btn.className = 'time-btn' + (TAKEN.includes(t) ? ' taken' : '');
            btn.textContent = t;
            if (!TAKEN.includes(t)) {
                btn.addEventListener('click', () => {
                    document.querySelectorAll('.time-btn').forEach(b => b.classList.remove('selected'));
                    btn.classList.add('selected');
                    bk.time = t;
                    document.getElementById('to3').disabled = false;
                });
            } else {
                btn.addEventListener('click', () => {
                    showToast('Este horario ya está ocupado. Por favor, elige otro disponible.');
                });
            }
            grid.appendChild(btn);
        });
    }

    document.getElementById('back1').addEventListener('click', () => goStep(1));
    document.getElementById('to3').addEventListener('click', () => {
        document.getElementById('sv-svc').textContent = bk.svc;
        document.getElementById('sv-date').textContent = bk.date;
        document.getElementById('sv-time').textContent = bk.time;
        document.getElementById('sv-price').textContent = bk.price;
        goStep(3);
    });
    document.getElementById('back2').addEventListener('click', () => goStep(2));

    document.getElementById('confirm').addEventListener('click', () => {
        const name = document.getElementById('f-name').value.trim();
        const phone = document.getElementById('f-phone').value.trim();
        document.getElementById('f-name').style.borderColor = name ? '' : '#ef4444';
        document.getElementById('f-phone').style.borderColor = phone ? '' : '#ef4444';
        if (!name || !phone) return;

        localStorage.setItem(BOOKING_KEY, JSON.stringify({
            svc: bk.svc, price: bk.price, date: bk.date, time: bk.time,
            name: name, phone: phone, ts: Date.now()
        }));

        document.getElementById('confirm-msg').textContent =
            `Hola ${name}, tu cita de "${bk.svc}" el ${bk.date} a las ${bk.time} está confirmada. Cualquier duda llámanos al 674 66 47 48.`;

        document.getElementById('s-ok').classList.add('active');
        document.querySelectorAll('.fstep:not(#s-ok)').forEach(s => s.classList.remove('active'));
        updateDots(4);
        renderBanner();
    });

    document.getElementById('new-booking').addEventListener('click', () => {
        Object.assign(bk, { svc:null, price:null, dur:null, date:null, dateObj:null, time:null });
        document.querySelectorAll('.svc-pick-btn').forEach(b => b.classList.remove('selected'));
        document.getElementById('to2').disabled = true;
        goStep(1);
    });

    // Init
    document.addEventListener('DOMContentLoaded', () => {
        renderBanner();
        buildCalendar();
    });
    if (document.readyState !== 'loading') { renderBanner(); buildCalendar(); }

    // ---- ACCESSIBILITY WIDGET ----
    (function() {
        const KEY = 'barber_a11y';
        const prefs = JSON.parse(localStorage.getItem(KEY) || '{}');

        function save() { localStorage.setItem(KEY, JSON.stringify(prefs)); }

        function applyFont(v, s=true) {
            document.documentElement.style.setProperty('--a11y-base', v + 'px');
            prefs.font = v; if (s) save();
            mark('font', String(v));
        }
        function applyContrast(v, s=true) {
            document.body.classList.remove('a11y-high-contrast','a11y-inverted');
            if (v==='high') document.body.classList.add('a11y-high-contrast');
            if (v==='inverted') document.body.classList.add('a11y-inverted');
            prefs.contrast = v; if (s) save(); mark('contrast', v);
        }
        function applyColor(v, s=true) {
            document.body.classList.remove('a11y-deuteranopia','a11y-protanopia','a11y-grayscale');
            if (v!=='normal') document.body.classList.add('a11y-'+v);
            prefs.color = v; if (s) save(); mark('color', v);
        }
        function applyMotion(v, s=true) {
            document.body.classList.remove('a11y-reduced-motion','a11y-no-motion');
            if (v==='reduced') document.body.classList.add('a11y-reduced-motion');
            if (v==='off')     document.body.classList.add('a11y-no-motion');
            prefs.motion = v; if (s) save(); mark('motion', v);
        }
        function mark(t, v) {
            document.querySelectorAll(`[data-t="${t}"]`).forEach(b => b.classList.toggle('on', b.dataset.v===v));
        }

        if (prefs.font)     applyFont(prefs.font, false);
        if (prefs.contrast) applyContrast(prefs.contrast, false);
        if (prefs.color)    applyColor(prefs.color, false);
        if (prefs.motion)   applyMotion(prefs.motion, false);

        const fab   = document.getElementById('a11y-fab');
        const panel = document.getElementById('a11y-panel');
        const close = document.getElementById('a11y-close');
        const reset = document.getElementById('a11y-reset');

        fab?.addEventListener('click', () => panel?.classList.toggle('open'));
        close?.addEventListener('click', () => panel?.classList.remove('open'));

        document.querySelectorAll('[data-t]').forEach(btn => {
            btn.addEventListener('click', () => {
                const {t, v} = btn.dataset;
                if (t==='font')     applyFont(Number(v));
                if (t==='contrast') applyContrast(v);
                if (t==='color')    applyColor(v);
                if (t==='motion')   applyMotion(v);
            });
        });

        reset?.addEventListener('click', () => {
            localStorage.removeItem(KEY);
            document.documentElement.style.removeProperty('--a11y-base');
            document.body.classList.remove('a11y-high-contrast','a11y-inverted','a11y-deuteranopia','a11y-protanopia','a11y-grayscale','a11y-reduced-motion','a11y-no-motion');
            ['font','contrast','color','motion'].forEach(t => mark(t, t==='font'?'16':'normal'));
        });
    })();

    // ---- HAMBURGER MOBILE NAV ----
    const ham = document.getElementById('nav-ham-pel');
    const navUl = document.getElementById('nav-ul-pel');
    if (ham && navUl) {
        ham.addEventListener('click', () => {
            const open = navUl.classList.toggle('open');
            ham.classList.toggle('open', open);
            ham.setAttribute('aria-expanded', open);
        });
        navUl.querySelectorAll('a').forEach(a => {
            a.addEventListener('click', () => {
                navUl.classList.remove('open');
                ham.classList.remove('open');
                ham.setAttribute('aria-expanded', 'false');
            });
        });
        document.addEventListener('click', e => {
            if (!ham.contains(e.target) && !navUl.contains(e.target)) {
                navUl.classList.remove('open');
                ham.classList.remove('open');
                ham.setAttribute('aria-expanded', 'false');
            }
        });
    }
</script>

</body>
</html>
